# Copy this file to terraform.tfvars and fill in the values before running
# terraform init / plan / apply.
#
# DO NOT commit terraform.tfvars to source control — it contains secrets.

# ── Konnect account ───────────────────────────────────────────────────────────
# (also set in provider.tf / environment; these drive the workshop resources)
# konnect_personal_access_token = "<USE_ENV_VARS>"

# ── Student cohort ────────────────────────────────────────────────────────────

student_count        = 20
student_start_number = 1       # Change to 21 to add a second batch without re-provisioning the first
student_name_prefix  = "student-"

control_plane_description = "Kong Data Path Workshop — environment for"
control_plane_labels = {
  workshop = "data-path"
  cohort   = "2026-Q1"
}

# ── LLM API keys (stored in Konnect Vault — students never see these) ─────────

llm_api_key_openai    = "sk-..."
llm_api_key_anthropic = "sk-ant-..."    # Leave empty ("") to skip Lab 3 failover provisioning

# ── Semantic Cache Redis (stored in Konnect Vault — students never see these) ─

redis_host     = "your-redis-host.example.com"
redis_port     = 6379
redis_username = "default"
redis_password = "your-redis-password"

# ── Kafka (Lab 4 only) ────────────────────────────────────────────────────────

kafka_bootstrap_servers = ""   # e.g. "b-1.mycluster.kafka.us-east-1.amazonaws.com:9092"
                               # Leave empty to skip

# ── SSO/OIDC Configuration ────────────────────────────────────────────────────
# Set enable_sso_config = false if you already have an identity provider configured

enable_sso_config                = true              # Set to false if identity provider already exists
workshop_sso_oidc_org_login_path = "<REPLACE_ME>"   # MANDATORY: OIDC login path for your workshop
# workshop_sso_oidc_issuer       = "https://workshop-idp.com"    # Optional: defaults to workshop-idp.com
# workshop_sso_oidc_client_id    = "workshop-client-12345"       # Optional: defaults to workshop-client-12345  
# workshop_sso_oidc_client_secret = "L2bQ8nZ5yX1wJ"               # Optional: defaults to L2bQ8nZ5yX1wJ
