# ── Kong Gateway ────────────────────────────────────────────────────────────
# Public URL of your Konnect Serverless Gateway proxy.
# Provided by the instructor via the Educates environment.
PROXY=https://your-gateway.kongcloud.dev

# ── LLM Proxy (Lab 3+) ──────────────────────────────────────────────────────
# Kong AI Gateway route URL. In Labs 1–2 the agent calls the LLM directly;
# from Lab 3 onward all LLM traffic is routed through this endpoint.
# Defaults to direct OpenAI access if not set.
LLM_PROXY=https://api.openai.com

# ── LLM Provider ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model to use — any model your LLM_PROXY supports
LLM_MODEL=gpt-4o-mini

# ── Agent Identity (Lab 2+) ──────────────────────────────────────────────────
# API key issued by Kong for the 'expense-agent' consumer.
# Provided by the instructor. Leave empty for Lab 1.
AGENT_API_KEY=

# ── Tool MCP Endpoints ───────────────────────────────────────────────────────
# In Lab 1 you configure these manually as Kong routes in Konnect.
# The agent reads them from env so you don't have to change code between labs.

# MCP endpoint for the expense service (approve/reject/escalate tools)
EXPENSE_MCP_URL=${PROXY}/mcp/expense

# MCP endpoint for the HR service (employee/department lookup tools)
HR_MCP_URL=${PROXY}/mcp/hr

# MCP endpoint for the policy service (policy lookup + evaluate tools)
POLICY_MCP_URL=${PROXY}/mcp/policy
